{
  "expo": {
    "name": "SparkyFitnessMobile",
    "slug": "sparkyfitnessmobile",
    "version": "1.5.0",
    "scheme": "sparkyfitnessmobile",
    "orientation": "portrait",
    "icon": "./assets/icons/appstore.png",
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "يحتاج سباركي فتنس إلى الوصول لبيانات النشاط والتمارين وقياسات الجسم عشان يعرضها لك ويزامنها مع خادمك.",
          "NSHealthUpdateUsageDescription": "يكتب سباركي فتنس بيانات التغذية والماء اللي تسجلها إلى تطبيق صحتي عشان تبقى بياناتك متزامنة.",
          "background": true
        }
      ],
      "expo-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 26
          }
        }
      ],
      "react-native-health-connect",
      "expo-web-browser",
      "expo-font",
      "expo-asset",
      "expo-background-task",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "يحتاج سباركي فتنس إلى الكاميرا عشان يمسح باركود المنتجات وملصقات القيم الغذائية.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#e2e2e2",
          "imageWidth": 200,
          "image": "./assets/images/splash.png",
          "dark": {
            "backgroundColor": "#232323",
            "image": "./assets/images/splash.png"
          }
        }
      ],
      ["expo-notifications"],
      [
        "expo-navigation-bar",
        {
          "enforceContrast": false
        }
      ],
      ["@bacons/apple-targets"]
    ],
    "experiments": {
      "reactCompiler": true,
      "autolinkingModuleResolution": true
    },
    "extra": {
      "eas": {
        "projectId": "498a86c5-344f-4d2c-9033-dfd720e4a383"
      },
      "APP_VARIANT": "production"
    }
  }
}
