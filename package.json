{
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "SparkyFitnessFrontend/**/*.{ts,tsx}": [
      "npx prettier --write"
    ],
    "SparkyFitnessServer/**/*.{js,ts}": [
      "npx prettier --write"
    ]
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "current",
        "linux"
      ],
      "cpu": [
        "current",
        "x64",
        "arm64"
      ]
    },
    "overrides": {
      "side-channel": "1.0.6",
      "tailwindcss": "4.2.1",
      "assistant-cloud": "0.1.33",
      "zustand": "5.0.14",
      "@xmldom/xmldom": "0.8.13",
      "fast-uri": "3.1.2",
      "form-data": "4.0.6",
      "hono": "4.12.25",
      "lodash": "4.18.1",
      "node-forge": "1.4.0",
      "path-to-regexp": "8.4.0",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.5": "4.0.5",
      "shell-quote": "1.8.4",
      "vite@>=8.0.0 <=8.0.15": "8.0.16",
      "ws@>=7.0.0 <7.5.11": "7.5.11",
      "ws@>=8.0.0 <8.21.0": "8.21.0"
    },
    "onlyBuiltDependencies": [
      "@scarf/scarf",
      "@shopify/react-native-skia",
      "@swc/core",
      "@parcel/watcher",
      "bcrypt",
      "sharp",
      "esbuild",
      "unrs-resolver",
      "vue-demi"
    ]
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
