# syntax=docker/dockerfile:1.4

# Stage 1: Install workspace dependencies and build MCP server
FROM node:24-alpine AS mcp_builder

RUN corepack enable

WORKDIR /app

# Copy workspace root files for pnpm resolution
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

# Copy all workspace member package.json files for dependency graph resolution
COPY SparkyFitnessServer/package.json SparkyFitnessServer/
COPY SparkyFitnessFrontend/package.json SparkyFitnessFrontend/
COPY SparkyFitnessMobile/package.json SparkyFitnessMobile/
COPY SparkyFitnessMCP/package.json SparkyFitnessMCP/
COPY shared/package.json shared/

# Install workspace dependencies
RUN pnpm install --frozen-lockfile

# Copy source
COPY shared/ shared/
COPY SparkyFitnessMCP/ SparkyFitnessMCP/

# Build TypeScript
RUN pnpm --filter=sparkyfitness-mcp-server build

# Deploy MCP server to standalone directory (flat node_modules, no workspace symlinks)
RUN pnpm --filter=sparkyfitness-mcp-server deploy --legacy /deploy

# Stage 2: Runtime container for MCP server
FROM node:24-alpine

WORKDIR /app/SparkyFitnessMCP

# Copy the built dist and deployed node_modules
COPY --from=mcp_builder /deploy ./
COPY --from=mcp_builder /app/SparkyFitnessMCP/dist ./dist

# Expose the MCP server port
EXPOSE 3011

# Healthcheck
HEALTHCHECK --interval=5s --timeout=10s --retries=5 CMD ["node", "-e", "require('http').get('http://127.0.0.1:3011/health', (r) => process.exit(r.statusCode === 200 ? 0 : 1)).on('error', () => process.exit(1))"]

# Run the built MCP server
CMD ["node", "dist/index.cjs"]
